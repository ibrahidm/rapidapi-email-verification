# Database (optional - for usage tracking)
DATABASE_URL=postgresql://user:password@localhost:5432/email_verification

# RapidAPI Authentication (required for production)
RAPIDAPI_PROXY_SECRET=your-secret-from-rapidapi

# SMTP Verification
SMTP_TIMEOUT_MS=10000
SMTP_FROM_DOMAIN=verify.yourdomain.com

# Rate Limiting
# Set to 'true' to disable rate limiting (testing only)
RATE_LIMIT_DISABLED=false
