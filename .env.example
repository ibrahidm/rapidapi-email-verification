# Database
DATABASE_URL=postgresql://user:password@localhost:5432/email_verification

# RapidAPI (leave empty for development)
RAPIDAPI_PROXY_SECRET=

# SMTP Verification
SMTP_TIMEOUT_MS=10000
SMTP_FROM_DOMAIN=verify.gdisoftware.com

# Rate Limiting (backup)
RATE_LIMIT_PER_MINUTE=100

# Optional
LOG_LEVEL=info
